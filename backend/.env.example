FLASK_DEBUG=1
# Generate a real random value (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
# Do not use this placeholder in production — JWTs are signed with this key.
SECRET_KEY=change-me

# CORS: leave as * for local dev. In production, set your real frontend origin(s).
# Comma-separate multiple origins (e.g. prod + Vercel preview URLs):
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-frontend-git-main.vercel.app
CORS_ORIGINS=*

# Days a login JWT stays valid
JWT_EXPIRY_DAYS=7

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=skillswap

# Optional: override the built MySQL URL
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/skillswap?charset=utf8mb4

OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# SMTP — used for welcome, password-reset, exchange-request and session emails.
# Leave blank in development: emails are then written to backend/data/outbox/ as .txt files.
# (in FLASK_DEBUG mode the reset link is returned in the API response instead).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SkillSwap <no-reply@skillswap.io>

# Base URL of the frontend, used to build links inside emails
FRONTEND_URL=http://localhost:5173

# Firebase project ID — required to verify Google Sign-In ID tokens from the client.
# Must match the Firebase project used by the frontend VITE_FIREBASE_PROJECT_ID.
FIREBASE_PROJECT_ID=
